{
    "name": "any-code-server",
    "version": "0.0.1",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "any-code-server": "dist/cli.js"
    },
    "scripts": {
        "build": "tsup",
        "dev": "pnpm --filter @any-code/agent build && tsup && node dist/index.js",
        "start": "pnpm --filter @any-code/agent build && pnpm --filter app build && tsup && concurrently \"node dist/index.js\" \"pnpm --filter app preview --port 5173\""
    },
    "dependencies": {
        "@any-code/agent": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "concurrently": "^9.1.0",
        "sql.js": "^1.12.0",
        "tsup": "^8.4.0",
        "typescript": "^5.7.0"
    }
}