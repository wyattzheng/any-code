{
  "name": "@any-code/settings",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./shared": {
      "types": "./shared.d.ts",
      "import": "./dist/shared.js",
      "require": "./dist/shared.js",
      "default": "./dist/shared.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "index.d.ts"
      ],
      "shared": [
        "shared.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "index.d.ts",
    "shared.d.ts"
  ],
  "dependencies": {
    "@any-code/provider": "workspace:*"
  },
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
